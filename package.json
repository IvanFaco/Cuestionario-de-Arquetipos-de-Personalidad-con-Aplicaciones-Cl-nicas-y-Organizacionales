{
  "name": "mi-real-yo-migration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scaffold inicial para migrar MiRealYo desde Streamlit hacia Express + TypeScript + EJS.",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts",
    "verify": "npm run build && npm run test",
    "start": "node dist/app.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
