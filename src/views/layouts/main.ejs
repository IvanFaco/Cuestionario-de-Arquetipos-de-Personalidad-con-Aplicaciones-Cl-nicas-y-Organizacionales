<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title><%= title %></title>
    <meta name="description" content="<%= seo.description %>" />
    <meta name="robots" content="<%= seo.robots %>" />
    <meta name="theme-color" content="#f5fbff" />
    <meta name="color-scheme" content="light" />
    <meta name="application-name" content="MiRealYo" />
    <meta name="apple-mobile-web-app-title" content="MiRealYo" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="canonical" href="<%= seo.canonicalUrl %>" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:type" content="<%= seo.ogType %>" />
    <meta property="og:title" content="<%= seo.title %>" />
    <meta property="og:description" content="<%= seo.description %>" />
    <meta property="og:url" content="<%= seo.canonicalUrl %>" />
    <meta property="og:site_name" content="MiRealYo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="<%= seo.title %>" />
    <meta name="twitter:description" content="<%= seo.description %>" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="/assets/logo-256.png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/assets/logo-256.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700&family=Roboto+Slab:wght@400;700&family=Sora:wght@700;800&display=swap" rel="stylesheet" />
    <link href="<%= appearanceFont.href %>" rel="stylesheet" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.8/dist/<%= appearance.bootswatchTheme %>/bootstrap.min.css"
    />
    <link rel="stylesheet" href="/styles/migration.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/styles/identity.css?v=<%= assetVersion %>" />
    <style>
      :root {
        --app-font-family-body: "<%= appearanceFont.family %>", sans-serif;
        --app-font-family-heading: "<%= appearanceFont.family %>", sans-serif;
        --app-h1-scale: <%= appearance.headingScale ?? 1 %>;
        --app-h2-scale: <%= appearance.subheadingScale ?? 1 %>;
        --app-h3-scale: <%= appearance.subheadingScale ?? 1 %>;
        --app-p-scale: <%= appearance.bodyScale ?? 1 %>;
      }
    </style>
  </head>
  <body>
    <%
    const currentPath = pageData?.currentPath || '';
    const sessionData = session || {};
    const authSession = sessionData.auth || null;
    const assessmentSession = sessionData.assessment || {};
    const sessionLead = assessmentSession.leadName;
    const sessionQuickResult = assessmentSession.hookOutcome;
    const sessionFullResult = assessmentSession.premiumOutcome;
    const sessionHomeHref = sessionFullResult ? '/full-results' : '/daily';
    const sessionStatusLabel = sessionFullResult ? 'Sesion activa | lectura lista' : 'Sesion activa | daily';
    const hasLeadName = sessionLead || currentPath === '/empezar' || currentPath.startsWith('/quick-test') || currentPath.startsWith('/quick-results') || currentPath.startsWith('/onboarding') || currentPath.startsWith('/full-test') || currentPath.startsWith('/full-results') || currentPath === '/registro';
    const hasQuickResult = sessionQuickResult || currentPath.startsWith('/quick-results') || currentPath.startsWith('/onboarding') || currentPath.startsWith('/full-test') || currentPath.startsWith('/full-results') || currentPath === '/registro';
    const hasFullResult = sessionFullResult || currentPath.startsWith('/full-results') || currentPath === '/registro';
    %>
    <aside class="app-sidebar">
      <nav class="app-sidebar__nav">
        <a href="/" class="app-sidebar__link" title="Splash"></a>
        <% if (hasLeadName) { %>
          <a href="/empezar" class="app-sidebar__link" title="Onboarding"></a>
        <% } else { %>
          <span class="app-sidebar__link is-disabled" title="Onboarding"></span>
        <% } %>
        <% if (hasLeadName) { %>
          <a href="/quick-test" class="app-sidebar__link" title="Quick Test"></a>
        <% } else { %>
          <span class="app-sidebar__link is-disabled" title="Quick Test"></span>
        <% } %>
        <% if (hasQuickResult) { %>
          <a href="/quick-results" class="app-sidebar__link" title="Quick Results"></a>
        <% } else { %>
          <span class="app-sidebar__link is-disabled" title="Quick Results"></span>
        <% } %>
        <% if (hasFullResult) { %>
          <a href="/full-results" class="app-sidebar__link" title="Full Results"></a>
        <% } else { %>
          <span class="app-sidebar__link is-disabled" title="Full Results"></span>
        <% } %>
        <% if (authSession) { %>
          <a href="<%= sessionHomeHref %>" class="app-sidebar__link" title="Sesion"></a>
        <% } else { %>
          <a href="/registro" class="app-sidebar__link" title="Registro"></a>
        <% } %>
      </nav>
    </aside>
    <main class="app-frame">
      <%- include("../partials/app-stage", { page, pageData }) %>
    </main>
    <% if (authSession) { %>
      <div class="app-session-badge">
        <span class="app-session-badge__dot" aria-hidden="true"></span>
        <a href="<%= sessionHomeHref %>" class="app-session-badge__link">
          <span><%= sessionStatusLabel %></span>
          <strong><%= authSession.email %></strong>
        </a>
        <form action="/logout" method="post" class="app-session-badge__logout-form">
          <button type="submit" class="app-session-badge__logout">Salir</button>
        </form>
      </div>
    <% } %>
    <footer class="app-footer">
      <a href="/privacidad" class="app-footer__link" target="_blank" rel="noopener noreferrer">Pol&iacute;ticas de Privacidad</a>
    </footer>
    <script src="/scripts/pwa.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
