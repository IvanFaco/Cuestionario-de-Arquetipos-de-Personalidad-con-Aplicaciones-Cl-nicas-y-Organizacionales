  <div class="app-stage-shell <%= isTestUx ? 'app-stage-shell--test' : 'app-stage-shell--default' %>">
    <header class="app-header">
      <div class="app-header__home" data-home-nav data-home-url="<%= siteRootUrl %>">
        <img src="/assets/logo-256.png" alt="MiRealYo" class="app-header__logo" />
        <span class="app-header__brand">MiRealYo.com</span>
      </div>
      <button
        type="button"
        class="app-header__theme-toggle"
        data-theme-toggle
        aria-label="Cambiar modo claro u oscuro"
        title="Cambiar modo claro u oscuro"
      >
        <span class="app-header__theme-toggle-icon" data-theme-toggle-icon aria-hidden="true">☀</span>
        <span class="app-header__theme-toggle-label" data-theme-toggle-label>Claro</span>
      </button>
    </header>
  <section class="app-stage">
    <div class="app-stage__inner">
      <%- include(page, { pageData }) %>
    </div>
  </section>
</div>
