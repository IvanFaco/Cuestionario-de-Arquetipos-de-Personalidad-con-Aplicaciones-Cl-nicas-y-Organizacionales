<form action="/onboarding/start" method="post" id="onboarding-form" class="stage-page">
  <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 w-100">
    <section class="landing-form-panel">
      <div class="compact-stack">
        <div>
          <p class="eyebrow mb-2">Un paso m&aacute;s</p>
          <h2 class="landing-form-title mb-1">Antes de mostrar tu lectura</h2>
          <p class="hero-copy mb-0">Ya te conocemos como <strong><%= pageData.name %></strong>. Ahora cu&eacute;ntanos qu&eacute; buscas al conocerte mejor.</p>
        </div>

        <div class="objective-chips">
          <% pageData.objectiveOptions.forEach((option) => { %>
            <label class="objective-chip <%= pageData.selectedObjective === option.value ? 'objective-chip--selected' : '' %>">
              <input
                type="radio"
                name="objetivo"
                value="<%= option.value %>"
                <%= pageData.selectedObjective === option.value ? "checked" : "" %>
                required
              />
              <span class="objective-chip__label"><%= option.label %></span>
            </label>
          <% }) %>
        </div>

        <div class="surface-note">
          Tus respuestas del test siguen siendo la base del resultado. Este paso solo nos ayuda a entregarte una devoluci&oacute;n m&aacute;s personal.
        </div>
        <% if (pageData.error) { %>
          <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
        <% } %>
      </div>
    </section>
  </div>

  <footer class="question-actions">
    <a class="question-actions__back" href="/quick-test/10">
      <span aria-hidden="true">&#8592;</span>
    </a>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">Seguir</button>
    </div>
  </footer>
</form>
