<form action="/onboarding/start" method="post" id="onboarding-form" class="stage-page">
  <section class="landing-form-panel">
    <div class="compact-stack">
      <div>
        <p class="eyebrow mb-2">Contexto inicial</p>
        <h2 class="landing-form-title mb-1">Antes de empezar</h2>
        <p class="hero-copy mb-0">Un poco de contexto para personalizar mejor tu lectura.</p>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="genero">
            ¿Con qué identidad te sientes más representado/a?
          </label>
          <select class="form-select form-select-lg compact-control" id="genero" name="genero" required>
            <option value="">Selecciona una opcion</option>
            <option value="Hombre">Masculina</option>
            <option value="Mujer">Femenina</option>
            <option value="Otro">No binaria / otra</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="rango_edad">Tu etapa de vida</label>
          <select class="form-select form-select-lg compact-control" id="rango_edad" name="rango_edad" required>
            <option value="">Selecciona</option>
            <option value="18_24">18 a 24 anos | exploracion e identidad emergente</option>
            <option value="25_34">25 a 34 anos | construccion y afirmacion del yo</option>
            <option value="35_49">35 a 49 anos | transicion, revision y metanoia</option>
            <option value="50_plus">50 anos o mas | integracion y sabiduria</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="orientacion_espiritual">
            Si quieres, puedes contarnos que tipo de mirada espiritual o filosofica sientes mas cercana.
          </label>
          <select
            class="form-select form-select-lg compact-control"
            id="orientacion_espiritual"
            name="orientacion_espiritual"
          >
            <option value="">Opcional</option>
            <option value="secular">Secular / no creyente</option>
            <option value="agnostic">Agnostico/a</option>
            <option value="spiritual_non_religious">Espiritual pero no religioso/a</option>
            <option value="believer_non_practicing">Creyente no practicante</option>
            <option value="religious_practicing">Religioso/a practicante</option>
            <option value="naturalist">Naturalista</option>
            <option value="buddhist">Budista</option>
            <option value="exploring">En busqueda</option>
            <option value="other">Otra</option>
            <option value="prefer_not_to_say">Prefiero no decirlo</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="energia_base">
            Cuando piensas en tu energia y presencia corporal, ¿que descripcion sientes mas cercana?
          </label>
          <select class="form-select form-select-lg compact-control" id="energia_base" name="energia_base" required>
            <option value="">Selecciona</option>
            <option value="ecto">Ligera, sensible y mas mental</option>
            <option value="meso">Activa, firme y orientada a la accion</option>
            <option value="endo">Estable, receptiva y de ritmo pausado</option>
            <option value="mixed">Mixta o cambiante segun el contexto</option>
          </select>
        </div>
      </div>
      <div class="surface-note">
        Esta informacion solo nos ayuda a personalizar mejor el analisis y el tono del reporte final. El resultado sigue dependiendo principalmente de tus respuestas en el test.
      </div>
      <% if (pageData.error) { %>
        <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
      <% } %>
    </div>
  </section>

  <footer class="question-actions">
    <span class="question-actions__back question-actions__back--ghost"></span>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">Seguir</button>
    </div>
  </footer>
</form>
