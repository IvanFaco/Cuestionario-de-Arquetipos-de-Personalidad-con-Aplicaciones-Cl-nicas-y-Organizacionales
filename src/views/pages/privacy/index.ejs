<section class="stage-page privacy-page">
  <header class="landing-hero privacy-page__hero">
    <div>
      <p class="eyebrow mb-2">Legal</p>
      <h1 class="landing-form-title mb-1">Pol&iacute;tica de Privacidad</h1>
      <p class="hero-copy mb-0">Resumen breve de c&oacute;mo usamos la informaci&oacute;n que compartes en MiRealYo.</p>
    </div>
  </header>

  <article class="question-card-panel privacy-panel">
    <div class="privacy-content">
      <p class="privacy-intro mb-0">
        Solo usamos tus datos para personalizar tu lectura, guardar tu avance y mostrar tus resultados.
      </p>

      <div class="privacy-stack">
        <section class="privacy-item">
          <h2 class="privacy-item__title">Qu&eacute; recopilamos</h2>
          <p class="privacy-item__copy mb-0">Tu nombre, pronombres opcionales y las respuestas del test.</p>
        </section>

        <section class="privacy-item">
          <h2 class="privacy-item__title">Para qu&eacute; lo usamos</h2>
          <p class="privacy-item__copy mb-0">Para construir tu lectura, mantener tu progreso y mejorar la experiencia.</p>
        </section>

        <section class="privacy-item">
          <h2 class="privacy-item__title">Qu&eacute; no hacemos</h2>
          <p class="privacy-item__copy mb-0">No vendemos tus datos ni los usamos para publicidad de terceros.</p>
        </section>

        <section class="privacy-item">
          <h2 class="privacy-item__title">Tus derechos</h2>
          <p class="privacy-item__copy mb-0">Puedes solicitar la eliminaci&oacute;n de tus datos cuando lo necesites.</p>
        </section>
      </div>

      <p class="privacy-meta mb-0">&Uacute;ltima actualizaci&oacute;n: <%= new Date().getFullYear() %></p>
    </div>
  </article>

  <footer class="question-actions">
    <button class="back-button question-actions__back" type="button" aria-label="Volver" onclick="window.history.length > 1 ? window.history.back() : window.location.assign('/')">
      <span aria-hidden="true">‹</span>
    </button>
    <div class="flex-grow-1">
      <a class="btn btn-primary app-cta question-actions__next" href="/">Ir al inicio</a>
    </div>
  </footer>
</section>
