<section class="hero-shell">
  <div class="hero-card">
    <p class="eyebrow mb-2">Dashboard estructural</p>
    <h1 class="display-6 fw-bold mb-3">Arquetipo dominante: <%= pageData.dominantArchetype %></h1>
    <p class="lead text-muted mb-4">Triada principal: <strong><%= pageData.topThree.join(", ") %></strong></p>

    <div class="row g-3 mb-4">
      <div class="col-12 col-md-4">
        <article class="phase-card h-100">
          <h2 class="h6">Persona</h2>
          <p class="display-6 mb-0"><%= pageData.persona %></p>
        </article>
      </div>
      <div class="col-12 col-md-4">
        <article class="phase-card h-100">
          <h2 class="h6">Sombra base</h2>
          <p class="display-6 mb-0"><%= pageData.sombraBase %></p>
        </article>
      </div>
      <div class="col-12 col-md-4">
        <article class="phase-card h-100">
          <h2 class="h6">Sombra total</h2>
          <p class="display-6 mb-0"><%= pageData.sombraTotal %></p>
        </article>
      </div>
    </div>

    <div class="alert alert-info" role="alert"><%= pageData.shadowLabel %></div>
    <div class="alert alert-secondary" role="alert">Keirsey: <strong><%= pageData.keirsey %></strong></div>
    <div class="alert alert-secondary" role="alert">Campbell: <strong><%= pageData.campbell %></strong></div>

    <h2 class="h5 mt-4">Ranking</h2>
    <div class="list-group list-group-flush mt-3">
      <% pageData.scores.forEach((item, index) => { %>
        <div class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
          <span><strong><%= index + 1 %>.</strong> <%= item.name %></span>
          <span class="badge text-bg-light border"><%= item.score.toFixed(1) %></span>
        </div>
      <% }) %>
    </div>

    <div class="alert alert-light border mt-4 mb-0" role="alert">
      El PDF y las visualizaciones se recuperan en la siguiente fase. El flujo SSR base ya esta operativo.
    </div>
  </div>
</section>
