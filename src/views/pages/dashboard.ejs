<section class="flow-shell">
  <div class="hero-card dashboard-card">
    <div class="compact-stack">
      <p class="eyebrow mb-1">Dashboard estructural</p>
      <div class="dashboard-head">
        <div>
          <h1 class="hero-title mb-1"><%= pageData.dominantArchetype %></h1>
          <p class="hero-copy mb-0">Triada principal: <strong><%= pageData.topThree.join(", ") %></strong></p>
        </div>
        <a class="btn btn-primary primary-cta primary-cta--small" href="/dashboard/pdf">PDF</a>
      </div>

      <div class="metrics-grid">
        <article class="metric-card">
          <span class="metric-card__label">Persona</span>
          <span class="metric-card__value"><%= pageData.persona %></span>
        </article>
        <article class="metric-card">
          <span class="metric-card__label">Sombra base</span>
          <span class="metric-card__value"><%= pageData.sombraBase %></span>
        </article>
        <article class="metric-card">
          <span class="metric-card__label">Sombra total</span>
          <span class="metric-card__value"><%= pageData.sombraTotal %></span>
        </article>
      </div>

      <div class="insight-stack">
        <div class="alert alert-info compact-alert mb-0" role="alert"><%= pageData.shadowLabel %></div>
        <div class="micro-panels">
          <div class="micro-panel">
            <span class="micro-panel__label">Keirsey</span>
            <strong><%= pageData.keirsey %></strong>
          </div>
          <div class="micro-panel">
            <span class="micro-panel__label">Campbell</span>
            <strong><%= pageData.campbell %></strong>
          </div>
        </div>
      </div>

      <section class="ranking-summary">
        <div class="d-flex justify-content-between align-items-center">
          <h2 class="h6 mb-0">Top 3</h2>
          <span class="text-muted small">12 arquetipos</span>
        </div>
        <div class="summary-ranking-list">
          <% pageData.scores.slice(0, 3).forEach((item, index) => { %>
            <div class="summary-ranking-item">
              <span class="summary-ranking-item__name"><strong><%= index + 1 %>.</strong> <%= item.name %></span>
              <span class="summary-ranking-item__score"><%= item.score.toFixed(1) %></span>
            </div>
          <% }) %>
        </div>
        <details class="ranking-details">
          <summary>Ver ranking completo</summary>
          <div class="summary-ranking-list mt-2">
            <% pageData.scores.forEach((item, index) => { %>
              <div class="summary-ranking-item">
                <span class="summary-ranking-item__name"><strong><%= index + 1 %>.</strong> <%= item.name %></span>
                <span class="summary-ranking-item__score"><%= item.score.toFixed(1) %></span>
              </div>
            <% }) %>
          </div>
        </details>
      </section>
    </div>
  </div>
</section>
