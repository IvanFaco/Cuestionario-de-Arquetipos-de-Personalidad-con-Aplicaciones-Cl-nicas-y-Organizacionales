<section class="stage-page splash-page">
  <div class="splash-page__center">
    <header class="splash-page__hero">
      <img src="/assets/logo-512.png" alt="MiRealYo" class="splash-logo mb-3" />
      <h1 class="hero-title mb-2">MiRealYo</h1>
      <p class="hero-copy mb-2">Descubre la parte de ti que más te representa, aquello que sueles ocultar y lo que realmente te mueve por dentro.</p>
      <% if (!session?.auth) { %>
        <a href="/login" class="link-primary fw-semibold text-decoration-none">Ya soy usuario, Iniciar sesión</a>
        <a href="/privacidad" class="link-secondary small text-decoration-underline">Política de privacidad</a>
      <% } %>
    </header>
  </div>

  <div class="splash-page__footer">
    <a class="btn btn-primary app-cta" href="/empezar">Comenzar</a>
  </div>
</section>
