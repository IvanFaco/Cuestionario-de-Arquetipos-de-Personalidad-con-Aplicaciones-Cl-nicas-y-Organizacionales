<section class="hero-shell">
  <div class="hero-card compact-stack">
    <div>
      <p class="eyebrow mb-2">Panel interno</p>
      <h1 class="display-6 fw-bold mb-2">DB</h1>
    </div>
    <p class="lead text-muted mb-0">
      Vista interna por URL directa para navegar tablas y consultar registros de la base de datos activa.
    </p>
  </div>
</section>

<section class="row g-3 mt-1">
  <div class="col-12">
    <article class="phase-card h-100 compact-stack">
      <div>
        <p class="eyebrow mb-2">Tablas</p>
        <h2 class="h5 mb-0">Explorador</h2>
      </div>

      <form action="/db" method="get" class="compact-stack">
        <div>
          <label class="form-label form-label-sm fw-semibold" for="table">Tabla</label>
          <select class="form-select compact-control" id="table" name="table">
            <% pageData.tables.forEach((table) => { %>
              <option value="<%= table.name %>" <%= pageData.selectedTable === table.name ? "selected" : "" %>>
                <%= table.name %> (<%= table.rowCount %>)
              </option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="form-label form-label-sm fw-semibold" for="limit">Límite de filas</label>
          <input
            class="form-control compact-control"
            id="limit"
            name="limit"
            type="number"
            min="1"
            max="200"
            value="<%= pageData.limit %>"
          />
        </div>

        <button class="btn btn-primary app-cta app-cta--compact" type="submit">Consultar</button>
      </form>

      <div class="surface-note">
        URL: <strong>/db</strong>
      </div>
    </article>
  </div>

  <div class="col-12">
    <article class="phase-card h-100 compact-stack">
      <% if (!pageData.selectedTableData) { %>
        <div>
          <p class="eyebrow mb-2">Consulta</p>
          <h2 class="h5 mb-0">Sin datos</h2>
        </div>
        <div class="surface-note mb-0">
          No se encontró la tabla solicitada o aún no hay tablas disponibles.
        </div>
      <% } else { %>
        <div class="db-panel__header">
          <div>
            <p class="eyebrow mb-2">Consulta</p>
            <h2 class="h5 mb-0"><%= pageData.selectedTableData.table %></h2>
          </div>
          <span class="status-pill"><%= pageData.selectedTableData.rows.length %> filas</span>
        </div>

        <div class="db-columns">
          <% pageData.selectedTableData.columns.forEach((column) => { %>
            <article class="db-columns__item">
              <strong><%= column.name %></strong>
              <span><%= column.type %></span>
              <% if (column.isPrimaryKey) { %>
                <span>PK</span>
              <% } %>
              <% if (column.notNull) { %>
                <span>NN</span>
              <% } %>
            </article>
          <% }) %>
        </div>

        <div class="table-responsive">
          <table class="table table-sm align-middle db-table mb-0">
            <thead>
              <tr>
                <% pageData.selectedTableData.columns.forEach((column) => { %>
                  <th scope="col"><%= column.name %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% if (pageData.selectedTableData.rows.length === 0) { %>
                <tr>
                  <td colspan="<%= pageData.selectedTableData.columns.length %>" class="text-muted">
                    Esta tabla no tiene registros.
                  </td>
                </tr>
              <% } %>
              <% pageData.selectedTableData.rows.forEach((row) => { %>
                <tr>
                  <% pageData.selectedTableData.columns.forEach((column) => { %>
                    <% const value = row[column.name]; %>
                    <td>
                      <code>
                        <%= value === null
                          ? "null"
                          : typeof value === "object"
                            ? JSON.stringify(value)
                            : String(value) %>
                      </code>
                    </td>
                  <% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </article>
  </div>
</section>
