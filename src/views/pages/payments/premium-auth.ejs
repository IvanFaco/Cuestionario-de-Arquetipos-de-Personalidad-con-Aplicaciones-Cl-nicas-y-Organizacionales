<%
  const activeMode = pageData.activeMode === "login" ? "login" : "register";
%>

<section class="stage-page teaser-screen premium-auth-page">
  <header class="question-header teaser-screen__header">
    <p class="eyebrow mb-0">Estudio profundo</p>
    <h3 class="question-title teaser-screen__title">Guarda tu lectura antes de continuar</h3>
  </header>

  <article class="question-card-panel teaser-card premium-auth-card">
    <div class="question-card-panel__body teaser-card__body">
      <div class="teaser-card__copy">
        <p class="teaser-card__kicker mb-0">Acceso seguro</p>
        <h2 class="teaser-card__headline mb-0">Crea tu cuenta</h2>
        <p class="teaser-card__summary mb-0">
          Guardaremos tu lectura inicial en tu cuenta para que el pago desbloquee el estudio profundo aunque cierres esta pantalla.
        </p>
      </div>
    </div>

    <div class="premium-auth-note">
      <p class="premium-auth-note__title mb-0">Lo que pasa después</p>
      <div class="premium-auth-note__items">
        <span>Tu resultado básico queda guardado</span>
        <span>Wompi valida el cobro</span>
        <span>Se habilita el estudio full</span>
      </div>
    </div>

    <div class="premium-auth-switch" role="tablist" aria-label="Acceso a cuenta">
      <button
        class="premium-auth-switch__button <%= activeMode === 'register' ? 'is-active' : '' %>"
        type="button"
        data-auth-mode="register"
        aria-pressed="<%= activeMode === 'register' ? 'true' : 'false' %>"
      >
        Crear cuenta
      </button>
      <button
        class="premium-auth-switch__button <%= activeMode === 'login' ? 'is-active' : '' %>"
        type="button"
        data-auth-mode="login"
        aria-pressed="<%= activeMode === 'login' ? 'true' : 'false' %>"
      >
        Ya tengo cuenta
      </button>
    </div>

    <div class="premium-auth-panels">
      <form action="/pagos/estudio-profundo/registro" method="post" class="premium-auth-form <%= activeMode === 'register' ? 'is-active' : 'is-hidden' %>" data-auth-panel="register">
        <strong class="premium-auth-form__title">Crear cuenta</strong>
        <p class="premium-auth-form__copy mb-0">Si aún no tienes cuenta, este es el paso más corto para conservar tu progreso.</p>
        <% if (pageData.error && activeMode === 'register') { %>
          <p class="surface-note surface-note--tight text-error mb-0"><%= pageData.error %></p>
        <% } %>
        <input class="form-control compact-control" type="email" name="email" placeholder="Correo electrónico" value="<%= pageData.email || '' %>" autocomplete="email" required />
        <input class="form-control compact-control" type="password" name="password" placeholder="Contraseña" autocomplete="new-password" minlength="6" required />
        <button class="btn btn-primary app-cta app-cta--compact w-full" type="submit">Crear y pagar</button>
      </form>

      <form action="/pagos/estudio-profundo/login" method="post" class="premium-auth-form <%= activeMode === 'login' ? 'is-active' : 'is-hidden' %>" data-auth-panel="login">
        <strong class="premium-auth-form__title">Ya tengo cuenta</strong>
        <p class="premium-auth-form__copy mb-0">Si ya estás registrado, entra con tu cuenta y continúa al pago.</p>
        <% if (pageData.loginError && activeMode === 'login') { %>
          <p class="surface-note surface-note--tight text-error mb-0"><%= pageData.loginError %></p>
        <% } %>
        <input class="form-control compact-control" type="email" name="email" placeholder="Correo electrónico" value="<%= pageData.loginEmail || '' %>" autocomplete="email" required />
        <input class="form-control compact-control" type="password" name="password" placeholder="Contraseña" autocomplete="current-password" required />
        <button class="btn btn-outline w-full" type="submit">Entrar y pagar</button>
      </form>
    </div>
  </article>
</section>

<script>
  (() => {
    const root = document.querySelector(".premium-auth-page");
    if (!root) {
      return;
    }

    const buttons = root.querySelectorAll("[data-auth-mode]");
    const panels = root.querySelectorAll("[data-auth-panel]");

    const setMode = (mode) => {
      buttons.forEach((button) => {
        const isActive = button.getAttribute("data-auth-mode") === mode;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-auth-panel") === mode;
        panel.classList.toggle("is-active", isActive);
        panel.classList.toggle("is-hidden", !isActive);
      });
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setMode(button.getAttribute("data-auth-mode") || "register");
      });
    });
  })();
</script>
