<section class="stage-page teaser-screen">
  <header class="question-header teaser-screen__header">
    <a class="back-button question-header__back question-actions__back" href="/quick-results" aria-label="Volver">
      <span aria-hidden="true">‹</span>
    </a>
    <p class="eyebrow">Pago seguro</p>
    <h3 class="question-title teaser-screen__title">Activa tu estudio profundo</h3>
  </header>

  <article class="question-card-panel teaser-card">
    <div class="question-card-panel__body teaser-card__body">
      <div class="teaser-card__copy">
        <p class="teaser-card__kicker mb-0">MiRealYo profundo</p>
        <h2 class="teaser-card__headline mb-0">
          $<%= (pageData.payment.amountInCents / 100).toLocaleString("es-CO") %> COP
        </h2>
        <p class="teaser-card__summary mb-0">
          El pago desbloquea las preguntas complementarias y tu lectura estructural completa.
        </p>
      </div>
    </div>

    <div class="question-card-panel__selection teaser-card__insight">
      <span class="question-card-panel__selection-label">Referencia</span>
      <strong class="question-card-panel__selection-value"><%= pageData.payment.reference %></strong>
    </div>
  </article>

  <% if (!pageData.isConfigured) { %>
    <p class="surface-note text-error">
      La pasarela no está configurada. Define las variables Wompi antes de probar el pago.
    </p>
    <% if (pageData.allowLocalPaymentSimulation) { %>
      <form action="/pagos/estudio-profundo/simular-aprobado" method="post" class="question-actions teaser-screen__actions">
        <input type="hidden" name="reference" value="<%= pageData.payment.reference %>">
        <button class="btn btn-primary app-cta question-actions__next" type="submit">
          Simular pago aprobado
        </button>
      </form>
    <% } %>
  <% } else { %>
    <% if (pageData.isSandboxForced) { %>
      <p class="surface-note">
        Estás en entorno local/no productivo: el checkout se ejecuta en <strong>sandbox</strong> aunque WOMPI_ENV pida producción.
      </p>
    <% } %>
    <% if (!pageData.isWebhookConfigured) { %>
      <p class="surface-note">
        Checkout habilitado. Falta <code>WOMPI_EVENTS_SECRET</code>, así que la confirmación por webhook no estará activa hasta configurarlo.
      </p>
    <% } %>
    <form class="question-actions teaser-screen__actions" action="<%= pageData.checkout.checkoutUrl %>" method="get">
      <input type="hidden" name="public-key" value="<%= pageData.checkout.publicKey %>">
      <input type="hidden" name="currency" value="<%= pageData.checkout.currency %>">
      <input type="hidden" name="amount-in-cents" value="<%= pageData.checkout.amountInCents %>">
      <input type="hidden" name="reference" value="<%= pageData.checkout.reference %>">
      <input type="hidden" name="signature:integrity" value="<%= pageData.checkout.signature %>">
      <input type="hidden" name="redirect-url" value="<%= pageData.checkout.redirectUrl %>">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">
        Pagar con Wompi
      </button>
    </form>
  <% } %>
</section>
