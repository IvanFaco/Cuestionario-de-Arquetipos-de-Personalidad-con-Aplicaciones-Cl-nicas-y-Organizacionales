<section class="stage-page teaser-screen">
  <header class="question-header teaser-screen__header">
    <a class="back-button question-header__back question-actions__back" href="/quick-results" aria-label="Volver">
      <span aria-hidden="true">&#8249;</span>
    </a>
    <p class="eyebrow">Estado del pago</p>
    <h3 class="question-title teaser-screen__title">Estamos validando tu activacion</h3>
  </header>

  <article class="question-card-panel teaser-card">
    <div class="question-card-panel__body teaser-card__body">
      <div class="teaser-card__copy">
        <p class="teaser-card__kicker mb-0">Resultado de Wompi</p>
        <% if (pageData.payment && pageData.payment.status === "APPROVED") { %>
          <h2 class="teaser-card__headline mb-0">Pago aprobado</h2>
          <p class="teaser-card__summary mb-0">Tu estudio profundo ya esta activo. Vamos a continuar con el test.</p>
        <% } else if (pageData.payment && ["DECLINED", "ERROR", "VOIDED"].includes(pageData.payment.status)) { %>
          <h2 class="teaser-card__headline mb-0">No se aprobo el pago</h2>
          <p class="teaser-card__summary mb-0">Puedes volver a intentarlo con una nueva referencia.</p>
        <% } else if (pageData.reference) { %>
          <h2 class="teaser-card__headline mb-0">Referencia encontrada</h2>
          <p class="teaser-card__summary mb-0">Estamos verificando tu pago directamente con Wompi para continuar apenas quede confirmado.</p>
        <% } else { %>
          <h2 class="teaser-card__headline mb-0">Validacion pendiente</h2>
          <p class="teaser-card__summary mb-0">Si ya pagaste, espera unos segundos y vuelve a consultar para continuar con tu estudio.</p>
        <% } %>
      </div>
    </div>
  </article>

  <div class="question-actions teaser-screen__actions">
    <% if (pageData.payment && pageData.payment.status === "APPROVED" && pageData.isOwnPayment) { %>
      <a class="btn btn-primary app-cta question-actions__next" href="/full-test">Continuar estudio</a>
    <% } else { %>
      <a class="btn btn-primary app-cta question-actions__next" href="/pagos/estudio-profundo">Ver estado o reintentar</a>
    <% } %>
  </div>
</section>

<% if (pageData.shouldPoll && pageData.reference && pageData.transactionId) { %>
  <script>
    window.setTimeout(() => {
      const url = new URL(window.location.href);
      url.searchParams.set("reference", "<%= pageData.reference %>");
      url.searchParams.set("id", "<%= pageData.transactionId %>");
      window.location.replace(url.toString());
    }, 4000);
  </script>
<% } %>
