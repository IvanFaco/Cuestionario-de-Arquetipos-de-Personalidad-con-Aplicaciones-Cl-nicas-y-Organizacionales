<section class="stage-page teaser-screen teaser-screen--results teaser-screen--full-results">
  <header class="question-header teaser-screen__header">
    <p class="eyebrow">Lectura profunda</p>
    <h3 class="question-title teaser-screen__title">Tu resultado completo</h3>
  </header>

  <article class="question-card-panel teaser-card teaser-carousel" data-full-carousel>
    <div class="teaser-carousel__viewport">
      <div class="teaser-carousel__track">
        <section class="teaser-carousel__slide is-active" data-full-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Eje principal</p>
              <h2 class="teaser-card__headline mb-0"><%= pageData.dominantArchetype %></h2>
              <p class="teaser-card__summary mb-0"><%= pageData.interpretation.quickSummary %></p>
              <img src="/assets/<%= pageData.dominantArchetypeSlug %>.png" alt="<%= pageData.dominantArchetype %>" class="teaser-archetype-img mb-3" />
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-full-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Mapa de puntajes</p>
              <div class="result-score-list">
                <% pageData.scores.slice(0, 5).forEach((item, index) => { %>
                  <article class="result-score">
                    <span class="result-score__rank">#<%= index + 1 %></span>
                    <strong class="result-score__name"><%= item.displayName %></strong>
                    <span class="result-score__bar" aria-hidden="true">
                      <span class="result-score__fill" style="width: <%= Math.min(100, (item.score / 7.5) * 100).toFixed(0) %>%"></span>
                    </span>
                    <span class="result-score__value"><%= item.score.toFixed(1) %></span>
                  </article>
                <% }) %>
              </div>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-full-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Estructura interna</p>
              <div class="teaser-metrics">
                <article class="teaser-metric">
                  <span class="teaser-metric__rank">Persona</span>
                  <strong class="teaser-metric__name">Imagen publica</strong>
                  <span class="teaser-metric__score"><%= pageData.persona.toFixed(1) %>/5</span>
                </article>
                <article class="teaser-metric">
                  <span class="teaser-metric__rank">Sombra base</span>
                  <strong class="teaser-metric__name">Impulso inicial</strong>
                  <span class="teaser-metric__score"><%= pageData.sombraBase.toFixed(1) %>/5</span>
                </article>
                <article class="teaser-metric">
                  <span class="teaser-metric__rank">Sombra total</span>
                  <strong class="teaser-metric__name"><%= pageData.interpretation.shadow.label %></strong>
                  <span class="teaser-metric__score"><%= pageData.sombraTotal.toFixed(1) %>/5</span>
                </article>
              </div>
              <p class="teaser-card__summary mb-0"><%= pageData.interpretation.shadow.summary %></p>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-full-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Decision y etapa vital</p>
              <div class="result-insight-grid">
                <article class="result-insight">
                  <span class="result-insight__label">Keirsey</span>
                  <strong class="result-insight__title"><%= pageData.keirsey %></strong>
                  <p class="result-insight__copy mb-0"><%= pageData.interpretation.keirsey.summary %></p>
                </article>
                <article class="result-insight">
                  <span class="result-insight__label">Campbell</span>
                  <strong class="result-insight__title"><%= pageData.campbell %></strong>
                  <p class="result-insight__copy mb-0"><%= pageData.interpretation.campbell.summary %></p>
                </article>
              </div>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-full-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Que hacer ahora</p>
              <div class="result-action-list">
                <% pageData.interpretation.actionPlan.forEach((item, index) => { %>
                  <article class="result-action">
                    <span class="result-action__index"><%= index + 1 %></span>
                    <p class="result-action__copy mb-0"><%= item %></p>
                  </article>
                <% }) %>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <div class="teaser-carousel__footer">
      <div class="teaser-carousel__dots" role="tablist" aria-label="Secciones del resultado completo">
        <button class="teaser-carousel__dot is-active" type="button" data-full-dot aria-label="Eje principal"></button>
        <button class="teaser-carousel__dot" type="button" data-full-dot aria-label="Puntajes"></button>
        <button class="teaser-carousel__dot" type="button" data-full-dot aria-label="Estructura"></button>
        <button class="teaser-carousel__dot" type="button" data-full-dot aria-label="Decision"></button>
        <button class="teaser-carousel__dot" type="button" data-full-dot aria-label="Accion"></button>
      </div>

      <div class="teaser-carousel__controls">
        <button class="teaser-carousel__control" type="button" data-full-prev aria-label="Anterior">&larr;</button>
        <button class="teaser-carousel__control" type="button" data-full-next aria-label="Siguiente">&rarr;</button>
      </div>
    </div>
  </article>

  <section class="teaser-ranking" aria-label="Top 3">
    <% pageData.topThree.forEach((item, index) => { %>
      <article class="teaser-ranking__item">
        <span class="teaser-ranking__position">#<%= index + 1 %></span>
        <strong class="teaser-ranking__name"><%= item %></strong>
      </article>
    <% }) %>
  </section>

  <footer class="question-actions">
    <a class="btn btn-primary app-cta" href="/full-results/pdf">Descargar informe completo</a>
  </footer>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-full-carousel]");
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-full-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-full-dot]"));
    const prev = root.querySelector("[data-full-prev]");
    const next = root.querySelector("[data-full-next]");
    let currentIndex = 0;

    const sync = () => {
      slides.forEach((slide, index) => {
        slide.classList.toggle("is-active", index === currentIndex);
      });
      dots.forEach((dot, index) => {
        dot.classList.toggle("is-active", index === currentIndex);
      });
    };

    prev?.addEventListener("click", () => {
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      sync();
    });

    next?.addEventListener("click", () => {
      currentIndex = (currentIndex + 1) % slides.length;
      sync();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        sync();
      });
    });
  })();
</script>
