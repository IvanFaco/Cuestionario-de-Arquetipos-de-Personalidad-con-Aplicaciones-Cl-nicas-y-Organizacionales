<section class="stage-page teaser-screen teaser-screen--results">
  <header class="question-header teaser-screen__header">
    <p class="eyebrow">Lectura inicial</p>
    <h3 class="question-title teaser-screen__title">Tu mapa visible ya tiene forma</h3>
  </header>

  <article class="question-card-panel teaser-card teaser-carousel" data-teaser-carousel>
    <div class="teaser-carousel__viewport">
      <div class="teaser-carousel__track">
        <section class="teaser-carousel__slide is-active" data-teaser-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Perfil parcial identificado</p>
              <h2 class="teaser-card__headline mb-0"><%= pageData.dominantArchetype %> al frente</h2>
              <p class="teaser-card__summary mb-0">
                <strong><%= pageData.name %></strong>, tu triada visible se ordena como
                <strong><%= pageData.topThree.join(", ") %></strong>.
              </p>
              <img src="/assets/<%= pageData.dominantArchetypeSlug %>.png" alt="<%= pageData.dominantArchetype %>" class="teaser-archetype-img mb-3" />
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-teaser-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Lectura humana</p>
              <div class="result-insight-grid">
                <article class="result-insight">
                  <span class="result-insight__label">Que te mueve</span>
                  <p class="result-insight__copy mb-0"><%= pageData.interpretation.dominant.motivation %></p>
                </article>
                <article class="result-insight">
                  <span class="result-insight__label">Que te potencia</span>
                  <p class="result-insight__copy mb-0"><%= pageData.interpretation.dominant.strength %></p>
                </article>
              </div>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-teaser-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Bajo presion</p>
              <p class="teaser-card__summary mb-0"><%= pageData.interpretation.dominant.stress %></p>
              <div class="teaser-metrics">
                <article class="teaser-metric">
                  <span class="teaser-metric__rank">Persona</span>
                  <strong class="teaser-metric__name">Imagen publica</strong>
                  <span class="teaser-metric__score"><%= pageData.persona.toFixed(1) %>/5</span>
                </article>
                <article class="teaser-metric">
                  <span class="teaser-metric__rank">Sombra base</span>
                  <strong class="teaser-metric__name">Impulso retenido</strong>
                  <span class="teaser-metric__score"><%= pageData.sombraBase.toFixed(1) %>/5</span>
                </article>
              </div>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-teaser-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy">
              <p class="teaser-card__kicker mb-0">Puntajes principales</p>
              <div class="teaser-metrics">
                <% pageData.topScores.forEach((item, index) => { %>
                  <article class="teaser-metric">
                    <span class="teaser-metric__rank">#<%= index + 1 %></span>
                    <strong class="teaser-metric__name"><%= item.displayName %></strong>
                    <span class="teaser-metric__score"><%= item.score.toFixed(1) %></span>
                  </article>
                <% }) %>
              </div>
            </div>
          </div>
        </section>

        <section class="teaser-carousel__slide" data-teaser-slide>
          <div class="question-card-panel__body teaser-card__body">
            <div class="teaser-card__copy teaser-card__copy--unlock">
              <p class="teaser-card__kicker mb-0">Lectura profunda</p>
              <h2 class="teaser-card__headline teaser-card__headline--unlock mb-0">Lo que falta por desbloquear</h2>
              <p class="teaser-card__summary teaser-card__summary--unlock mb-0">
                La calibracion completa cruza tu arquetipo visible con sombra, temperamento y etapa vital.
              </p>
              <div class="teaser-unlock-list" aria-label="Beneficios de la lectura profunda">
                <p class="teaser-unlock-list__item mb-0">
                  <strong>Mapa de 12 ejes:</strong> ranking visual de tus arquetipos dominantes y secundarios.
                </p>
                <p class="teaser-unlock-list__item mb-0">
                  <strong>Sombra bajo estres:</strong> que patron puede sabotearte cuando aumenta la presion.
                </p>
                <p class="teaser-unlock-list__item mb-0">
                  <strong>Temperamento de decision:</strong> como ordenar criterio, emocion y accion.
                </p>
                <p class="teaser-unlock-list__item teaser-unlock-list__item--gift mb-0">
                  <strong>Informe descargable:</strong> texto interpretativo con graficas para convertir insight en accion.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <div class="teaser-carousel__footer">
      <div class="teaser-carousel__dots" role="tablist" aria-label="Secciones de la lectura inicial">
        <button class="teaser-carousel__dot is-active" type="button" data-teaser-dot aria-label="Perfil"></button>
        <button class="teaser-carousel__dot" type="button" data-teaser-dot aria-label="Lectura humana"></button>
        <button class="teaser-carousel__dot" type="button" data-teaser-dot aria-label="Bajo presion"></button>
        <button class="teaser-carousel__dot" type="button" data-teaser-dot aria-label="Puntajes"></button>
        <button class="teaser-carousel__dot" type="button" data-teaser-dot aria-label="Lectura profunda"></button>
      </div>

      <div class="teaser-carousel__controls">
        <button class="teaser-carousel__control" type="button" data-teaser-prev aria-label="Anterior">&larr;</button>
        <button class="teaser-carousel__control" type="button" data-teaser-next aria-label="Siguiente">&rarr;</button>
      </div>
    </div>
  </article>

  <form action="/pagos/estudio-profundo" method="get" class="question-actions teaser-screen__actions">
    <span class="question-actions__back question-actions__back--ghost"></span>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">
        Profundizar mi lectura
      </button>
    </div>
  </form>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-teaser-carousel]");
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-teaser-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-teaser-dot]"));
    const prev = root.querySelector("[data-teaser-prev]");
    const next = root.querySelector("[data-teaser-next]");
    let currentIndex = 0;

    const sync = () => {
      slides.forEach((slide, index) => {
        slide.classList.toggle("is-active", index === currentIndex);
      });
      dots.forEach((dot, index) => {
        dot.classList.toggle("is-active", index === currentIndex);
      });
    };

    prev?.addEventListener("click", () => {
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      sync();
    });

    next?.addEventListener("click", () => {
      currentIndex = (currentIndex + 1) % slides.length;
      sync();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        sync();
      });
    });
  })();
</script>
