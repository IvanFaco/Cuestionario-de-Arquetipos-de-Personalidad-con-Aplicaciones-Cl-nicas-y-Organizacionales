<p class="eyebrow mb-0">Antes de empezar</p>
<form action="/empezar" method="post" class="stage-page">
  <section class="landing-form-panel my-auto">
    <div class="compact-stack">
      <div>
        <h2 class="landing-form-title mb-1">&iquest;C&oacute;mo quieres que te llamemos?</h2>
        <p class="hero-copy mb-0">Solo te pediremos tu nombre y, si quieres, tus pronombres para personalizar la experiencia.</p>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="nombre">Tu nombre</label>
          <input
            class="form-control compact-control"
            id="nombre"
            name="nombre"
            type="text"
            maxlength="60"
            required
            value="<%= pageData.name ?? '' %>"
          />
        </div>
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="pronombres">Tus pronombres</label>
          <select
            class="form-select compact-control"
            id="pronombres"
            name="pronombres"
          >
            <option value="">Opcional</option>
            <option value="&#233;l" <%= pageData.pronombres === 'él' ? 'selected' : '' %>>&Eacute;l / Him</option>
            <option value="ella" <%= pageData.pronombres === 'ella' ? 'selected' : '' %>>Ella / She</option>
            <option value="elle" <%= pageData.pronombres === 'elle' ? 'selected' : '' %>>Elle / They</option>
            <option value="otro" <%= pageData.pronombres === 'otro' ? 'selected' : '' %>>Otro</option>
          </select>
        </div>
      </div>

      <div class="surface-note">
        Usaremos esta informaci&oacute;n &uacute;nicamente para presentarte tu lectura de forma m&aacute;s cercana. No la usamos con fines publicitarios.
      </div>

      <label class="consent-check">
        <input
          class="consent-check__input"
          id="privacyAccepted"
          name="privacyAccepted"
          type="checkbox"
          value="yes"
          <%= pageData.privacyAccepted ? "checked" : "" %>
          required
        />
        <span class="consent-check__box" aria-hidden="true"></span>
        <span class="consent-check__copy">
          Acepto el tratamiento de mis datos conforme a la
          <a href="/privacidad" target="_blank" rel="noopener noreferrer">Pol&iacute;tica de Privacidad</a>.
        </span>
      </label>

      <% if (pageData.error) { %>
        <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
      <% } %>
    </div>
  </section>

  <footer class="question-actions">
    <a class="back-button question-actions__back" href="/" aria-label="Volver">
      <span aria-hidden="true">‹</span>
    </a>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">Seguir</button>
    </div>
  </footer>
</form>
