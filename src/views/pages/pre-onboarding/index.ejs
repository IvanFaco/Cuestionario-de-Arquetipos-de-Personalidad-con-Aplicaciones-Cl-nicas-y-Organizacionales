<form action="/empezar" method="post" class="stage-page">
  <section class="landing-form-panel my-auto">
    <div class="compact-stack">
      <div>
        <p class="eyebrow mb-2">Antes de empezar</p>
        <h2 class="landing-form-title mb-1">¿Cómo quieres que te llamemos?</h2>
        <p class="hero-copy mb-0">Por ahora, este es el único dato personal que te pediremos antes del quick test.</p>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="nombre">Tu nombre</label>
          <input
            class="form-control form-control-lg compact-control"
            id="nombre"
            name="nombre"
            type="text"
            maxlength="60"
            required
            value="<%= pageData.name ?? '' %>"
          />
        </div>
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="pronombres">Tus pronombres</label>
          <select
            class="form-select form-select-lg compact-control"
            id="pronombres"
            name="pronombres"
          >
            <option value="">Opcional</option>
            <option value="él" <%= pageData.pronombres === 'él' ? 'selected' : '' %>>Él / Him</option>
            <option value="ella" <%= pageData.pronombres === 'ella' ? 'selected' : '' %>>Ella / She</option>
            <option value="elle" <%= pageData.pronombres === 'elle' ? 'selected' : '' %>>Elle / They</option>
            <option value="otro" <%= pageData.pronombres === 'otro' ? 'selected' : '' %>>Otro</option>
          </select>
        </div>
      </div>

      <div class="surface-note">
        Lo usaremos para hacer la experiencia un poco más cercana mientras exploras tu lectura.
      </div>

      <% if (pageData.error) { %>
        <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
      <% } %>
    </div>
  </section>

  <footer class="question-actions">
    <a class="question-actions__back" href="/">
      <span aria-hidden="true">←</span>
    </a>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">Seguir</button>
    </div>
  </footer>
</form>
