<form action="/empezar" method="post" class="stage-page">
  <section class="landing-form-panel">
    <div class="compact-stack">
      <div>
        <p class="eyebrow mb-2">Antes de empezar</p>
        <h2 class="landing-form-title mb-1">¿Como quieres que te llamemos?</h2>
        <p class="hero-copy mb-0">Por ahora, este es el unico dato personal que te pediremos antes del quick test.</p>
      </div>

      <div class="row g-2">
        <div class="col-12">
          <label class="form-label form-label-sm fw-semibold" for="nombre">Tu nombre</label>
          <input
            class="form-control form-control-lg compact-control"
            id="nombre"
            name="nombre"
            type="text"
            maxlength="60"
            required
            value="<%= pageData.name ?? '' %>"
          />
        </div>
      </div>

      <div class="surface-note">
        Lo usaremos para hacer la experiencia un poco mas cercana mientras exploras tu lectura.
      </div>

      <% if (pageData.error) { %>
        <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
      <% } %>
    </div>
  </section>

  <footer class="question-actions">
    <a class="question-actions__back" href="/">
      <span aria-hidden="true">←</span>
    </a>
    <div class="flex-grow-1">
      <button class="btn btn-primary app-cta question-actions__next" type="submit">Seguir</button>
    </div>
  </footer>
</form>
