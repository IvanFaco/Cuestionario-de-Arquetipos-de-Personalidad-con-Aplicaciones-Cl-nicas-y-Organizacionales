<section class="hero-shell">
  <div class="hero-card">
    <p class="eyebrow mb-2">Mapa Psicologico Premium</p>
    <h1 class="display-5 fw-bold mb-3"><%= pageData.title %></h1>
    <p class="lead text-muted mb-4"><%= pageData.subtitle %></p>
    <div class="d-flex flex-wrap gap-2 mb-4">
      <span class="badge text-bg-light border">Hook quiz: <%= pageData.hookCount %> preguntas</span>
      <span class="badge text-bg-light border">Premium quiz: <%= pageData.premiumCount %> preguntas</span>
      <a class="badge text-bg-secondary text-decoration-none" href="/migration">Estado migracion</a>
    </div>

    <% if (pageData.error) { %>
      <div class="alert alert-danger" role="alert"><%= pageData.error %></div>
    <% } %>

    <form action="/start" method="post" class="vstack gap-3">
      <div>
        <label class="form-label fw-semibold" for="genero">Genero</label>
        <select class="form-select form-select-lg" id="genero" name="genero" required>
          <option value="">Selecciona una opcion</option>
          <option value="Hombre">Hombre</option>
          <option value="Mujer">Mujer</option>
          <option value="Otro">Otro</option>
        </select>
      </div>
      <div>
        <label class="form-label fw-semibold" for="edad_exacta">Edad exacta</label>
        <input
          class="form-control form-control-lg"
          id="edad_exacta"
          name="edad_exacta"
          type="number"
          min="18"
          max="99"
          value="35"
          required
        />
      </div>
      <button class="btn btn-primary btn-lg" type="submit">Continuar al test clinico</button>
    </form>
  </div>
</section>
