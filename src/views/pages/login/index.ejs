<section class="stage-page landing-page">
  <%- include("../../partials/assessment/onboarding-hero", { pageData }) %>
  <form action="/login" method="post" id="login-form" class="stage-page">
    <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 w-100">
      <section class="landing-form-panel">
        <div class="compact-stack">
          <div>
            <p class="eyebrow mb-0">Iniciar sesión</p>
            <h2 class="landing-form-title mb-1">Accede a tu lectura</h2>
            <p class="hero-copy mb-0">Ingresa tus credenciales para continuar donde lo dejaste.</p>
          </div>

          <div class="row g-2">
            <div class="col-12">
              <label class="form-label form-label-sm fw-semibold" for="email">Tu correo electrónico</label>
              <input
                class="form-control compact-control"
                id="email"
                name="email"
                type="email"
                required
                value="<%= pageData.email ?? '' %>"
              />
            </div>
            <div class="col-12">
              <label class="form-label form-label-sm fw-semibold" for="password">Tu contraseña</label>
              <input
                class="form-control compact-control"
                id="password"
                name="password"
                type="password"
                required
              />
            </div>
          </div>

          <div class="surface-note surface-note--tight">
            Si ya habías iniciado tu proceso, entra aquí para ver tu resultado sin repetir el flujo.
          </div>

          <% if (pageData.error) { %>
            <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
          <% } %>
        </div>
      </section>
    </div>

    <footer class="question-actions">
      <a class="back-button question-actions__back" href="/" aria-label="Volver">
        <span aria-hidden="true">‹</span>
      </a>
      <div class="flex-grow-1">
        <button type="submit" form="login-form" class="btn btn-primary app-cta question-actions__next">Entrar</button>
      </div>
    </footer>
  </form>
</section>
