<section class="stage-page landing-page">
  <form action="/registro" method="post" id="registro-form" class="stage-page">
    <section class="landing-form-panel my-auto">
      <div class="compact-stack">
        <div>
          <p class="eyebrow mb-2">Informe completo</p>
          <h2 class="landing-form-title mb-1">Crea tu cuenta</h2>
          <p class="hero-copy mb-0">Guarda tu lectura y accede a tu informe completo cuando quieras.</p>
        </div>

        <div class="row g-2">
          <div class="col-12">
            <label class="form-label form-label-sm fw-semibold" for="email">Tu correo electrónico</label>
            <input
              class="form-control compact-control"
              id="email"
              name="email"
              type="email"
              required
              value="<%= pageData.email ?? '' %>"
            />
          </div>
          <div class="col-12">
            <label class="form-label form-label-sm fw-semibold" for="password">Elige una contraseña</label>
            <input
              class="form-control compact-control"
              id="password"
              name="password"
              type="password"
              minlength="6"
              required
            />
          </div>
        </div>

        <input type="hidden" name="registrationIntent" value="<%= pageData.intent ?? 'account' %>" />

        <div class="surface-note">
          <% if ((pageData.intent ?? 'account') === 'download') { %>
            Al crear tu cuenta descargaremos tu informe completo en PDF inmediatamente.
          <% } else { %>
            Al crear tu cuenta continuaremos con el siguiente paso de tu proceso.
          <% } %>
        </div>

        <% if (pageData.error) { %>
          <div class="alert alert-danger compact-alert mb-0" role="alert"><%= pageData.error %></div>
        <% } %>
      </div>
    </section>

    <footer class="question-actions">
    <a class="back-button question-actions__back" href="/full-results" aria-label="Volver">
      <span aria-hidden="true">‹</span>
    </a>
      <div class="flex-grow-1">
        <button
          type="submit"
          form="registro-form"
          class="btn btn-primary app-cta question-actions__next"
        >
          <%= (pageData.intent ?? 'account') === 'download' ? 'Crear cuenta y descargar' : 'Crear cuenta' %>
        </button>
      </div>
    </footer>
  </form>
</section>
